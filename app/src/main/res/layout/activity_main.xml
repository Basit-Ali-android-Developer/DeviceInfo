<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/appBackground"
    tools:context=".navigation.MainActivity">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fitsSystemWindows="true">

    <!-- Toolbar with title and settings icon -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/toolBar"
        android:layoutDirection="ltr"
        android:textDirection="ltr"
        android:padding="10dp">

        <TextView
            android:id="@+id/toolbarTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/App_Title"
            android:textSize="20sp"
            android:textColor="?attr/text"
            android:fontFamily="sans-serif-medium"
            android:layout_gravity="center"/>

        <ImageView
            android:id="@+id/btnGoToSettings"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/settingsvg"
            app:tint="?attr/text"
            android:layout_gravity="end"
            android:layout_marginEnd="20dp"/>
    </androidx.appcompat.widget.Toolbar>

    <!-- Top Navigation Tabs -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tab"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:tabMode="scrollable"
        android:background="?attr/appBackground"
        app:tabIndicatorColor="@color/Heading_blue"
        app:tabTextColor="?attr/text"
        app:tabSelectedTextColor="@color/Heading_blue"/>

    <!-- ViewPager2 for pages -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>
</LinearLayout>

    <LinearLayout
        android:id="@+id/loaderOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="?attr/appBackground"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <ProgressBar
            android:layout_width="50dp"
            android:layout_height="50dp"/>

        <TextView
            android:id="@+id/loaderText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Loading..."
            android:textColor="?attr/text"
            android:textSize="16sp"
            android:layout_marginTop="12dp"/>
    </LinearLayout>

</FrameLayout>